{
  "compilerOptions": {
    "target":              "ES2022",
    "lib":                 ["ES2024", "DOM", "DOM.Iterable"],
    "module":              "ESNext",
    "moduleResolution":    "bundler",
    "jsx":                 "react-jsx",
    "strict":              true,
    "skipLibCheck":        true,
    "moduleDetection":     "force",
    "noEmit":              true,
    "paths": {
      "@strand/core": ["../../vendor/strand/src/index.ts"]
    }
  },
  "include": ["src"]
}
